import numpy as np
from mmseg.datasets.builder import PIPELINES


@PIPELINES.register_module()
class SyncMPDPixelTransform:

    def __call__(self, results):

        if 'mpd_pixel' not in results:
            return results
        mpd_dict = results['mpd_pixel']


        if results.get('flip', False):
            direction = results['flip_direction']
            for k in mpd_dict:
                mpd = mpd_dict[k]
                if direction == 'horizontal':
                    mpd = mpd[:, :, ::-1].copy()
                elif direction == 'vertical':
                    mpd = mpd[:, ::-1, :].copy()
                mpd_dict[k] = mpd


        if 'crop_bbox' in results:

            x1, y1, x2, y2 = results['crop_bbox']
            for k in mpd_dict:
                mpd = mpd_dict[k]
                mpd = mpd[:, y1:y2, x1:x2].copy()
                mpd_dict[k] = mpd

        results['mpd_pixel'] = mpd_dict

        return results
